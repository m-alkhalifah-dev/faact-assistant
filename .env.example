# FAACT Assistant — environment (copy to .env; .env is gitignored, NEVER commit real keys)
#
# ──────────────────────────────────────────────────────────────────────────────
# $0 DEMO MODE (default): leave everything below blank.
#   With no keys present, the assistant runs on the deterministic MOCK provider.
#   It answers real diploma/contact questions from the KB and defers on price/date.
#   Good enough to demo the machinery to Dr. Fahd at zero cost.
# ──────────────────────────────────────────────────────────────────────────────
#
# REAL-MODEL MODE (recommended for the truthfulness proof, still $0 on free Gemini):
#   1. Get a free key at https://aistudio.google.com/apikey
#   2. Set GEMINI_API_KEY below.
#   3. Run `npm run eval` — now the eval grades a REAL model's grounding behavior.
#
# Provider chain: comma-separated, tried in order. Only providers WITH a key are used.
# If none have a key, the mock provider is used.
LLM_CHAIN=gemini,groq

# --- Primary: free Gemini (huge context, OpenAI-compatible endpoint) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Fallback: Groq (fast, tighter daily caps — good as a 429 backup) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Optional: OpenRouter (another free fallback) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Optional: self-hosted (e.g. Gemma on the Oracle box; $0 + private) ---
# OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma2:9b

# --- Generation settings (low temperature = less drift = more truthful) ---
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=700
LLM_TIMEOUT_MS=30000
LLM_RETRIES_PER_PROVIDER=2
